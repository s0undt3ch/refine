{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // `config:recommended` brings the dependency dashboard, monorepo
  // groupings, and semantic commit prefixes. The pin-helper makes
  // every GitHub Action update keep the repo's existing
  // `sha # vX.Y.Z` pinning style.
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver",
  ],

  timezone: "Etc/UTC",
  schedule: ["before 6am on monday"],

  // Renovate's pre-commit manager is disabled by default — enable it so the
  // `rev:` pins in .pre-commit-config.yaml (conventional-pre-commit,
  // pre-commit-hooks, s0undt3ch/pre-commit-hooks) get bumped too.
  "pre-commit": {
    enabled: true,
  },

  // Remediate vulnerable *transitive* deps directly from OSV data — an
  // advisory on an indirect dep (one that lives only in uv.lock, never in
  // pyproject.toml) produces no PR otherwise, since the pep621 manager only
  // bumps manifest-declared deps. Security PRs bypass the weekly schedule.
  osvVulnerabilityAlerts: true,

  // Once a month, regenerate the lockfile (`uv lock`) to pull every dep —
  // direct and transitive — up to the newest version its existing manifest
  // range already allows. This does NOT widen the ranges themselves (that's
  // the regular per-dep PRs); it just keeps the locked graph current, so
  // transitive drift is caught before it turns into an OSV advisory. One
  // low-noise PR per month.
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am on the first day of the month"],
  },

  assignees: ["s0undt3ch"],
  labels: ["dependencies"],

  packageRules: [
    // ---- Ecosystem labels (mirror the old Dependabot setup) ----
    {
      description: "Tag Python (pyproject.toml) updates",
      matchManagers: ["pep621"],
      addLabels: ["dependencies:python"],
    },
    {
      description: "Tag GitHub Actions updates",
      matchManagers: ["github-actions"],
      addLabels: ["dependencies:github-actions"],
    },
    {
      description: "Tag pre-commit hook updates",
      matchManagers: ["pre-commit"],
      addLabels: ["dependencies:pre-commit"],
    },
    {
      description: "Tag mise Python / uv pins as Python",
      matchManagers: ["mise"],
      matchDepNames: ["python", "uv"],
      addLabels: ["dependencies:python"],
    },

    // ---- Grouping to cut PR noise ----
    {
      // GHA digest pins drift constantly; reviewing one weekly PR is
      // saner than one per action.
      description: "Group all GitHub Actions updates",
      groupName: "github-actions",
      matchManagers: ["github-actions"],
    },
    {
      // mise CLI tools (the pre-commit-hook binaries + prek) — group them so
      // we don't get a PR per tool. All are pinned to exact versions in
      // mise.toml (a `latest` pin has no version for Renovate to bump, so it
      // would be silently skipped).
      //
      // Match by manager and *exclude* the language toolchain / package
      // manager that we deliberately keep as their own ecosystem-tagged,
      // individually-reviewable PRs. Everything else — including any new CLI
      // tool later added to mise.toml — is grouped automatically, so there's
      // no hand-maintained allow-list to drift out of sync with mise.toml.
      description: "Group mise CLI tooling updates",
      groupName: "mise tools",
      matchManagers: ["mise"],
      matchDepNames: ["!python", "!uv"],
    },
  ],
}
